// Trigonometry is in degrees.
Print Str(Sin(0.0))
Print Str(Sin(90.0))
Print Str(Cos(0.0))
Print Str(Tan(0.0))
Print Str(ASin(1.0))
Print Str(ACos(1.0))
Print Str(ATan(0.0))

// General math.
Print Str(Sqrt(16.0))
Print Str(Log(1.0))
Print Str(Log10(100.0))
Print Str(RoundUp(2.3))
Print Str(RoundDown(2.7))

// Min / Max — int and float overloads.
Print Str(Max(3, 7))
Print Str(Min(3, 7))
Print Str(Max(3.5, 2.5))
Print Str(Min(3.5, 2.5))

// Geometry.
Print Str(Distance(0.0, 0.0, 3.0, 4.0))
Print Str(WrapAngle(370.0))
Print Str(WrapAngle(-10.0))
Print Str(GetAngle(0.0, 0.0, 0.0, 1.0))

// CurveValue / CurveAngle — deterministic easing.
Print Str(CurveValue(10.0, 0.0, 2.0))
Print Str(CurveValue(100.0, 50.0, 5.0))
// CurveAngle takes the shortest path across the 360 wrap: 10 -> 350 is -20,
// halved to -10, so 10 - (-10) ... wrapped lands on 0.
Print Str(CurveAngle(350.0, 10.0, 2.0))
Print Str(CurveAngle(0.0, 90.0, 2.0))

// BoxOverlap — AABB intersection (1) and disjoint (0).
Print Str(BoxOverlap(0.0, 0.0, 10.0, 10.0, 5.0, 5.0, 10.0, 10.0))
Print Str(BoxOverlap(0.0, 0.0, 10.0, 10.0, 50.0, 50.0, 10.0, 10.0))

// Int(Float) rounds to nearest, ties away from zero (-2.5 -> -3), not toward zero.
Print Str(Int(2.4))
Print Str(Int(2.5))
Print Str(Int(-2.5))
// Int(String) trims and parses a leading integer; 0 on no digits.
Print Str(Int("42"))
Print Str(Int("  17abc"))
Print Str(Int("xyz"))

// Random — values are non-deterministic, so assert ranges instead of golden
// values. Rand is INCLUSIVE [low,high] (cbEnchanted parity); Rnd is [low,high).
Randomize(12345)
i = Rand(10)
If i >= 0 And i <= 10 Then Print "rand_ok"
j = Rand(100, 110)
If j >= 100 And j <= 110 Then Print "rand_range_ok"
f# = Rnd(5.0)
If f# >= 0.0 And f# < 5.0 Then Print "rnd_ok"
g# = Rnd(2.0, 3.0)
If g# >= 2.0 And g# < 3.0 Then Print "rnd_range_ok"
