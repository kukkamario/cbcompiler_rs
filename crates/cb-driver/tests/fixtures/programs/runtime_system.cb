// Timer is non-deterministic, so assert invariants (non-negative, monotonic)
// as booleans rather than golden values.
If Timer() >= 0 Then Print "timer_nonneg"
t = Timer()
Wait(1)
If Timer() >= t Then Print "timer_monotonic"

// Date/time/process info — environment-dependent, so assert structure
// (exact values change every run) and that each call succeeds.
If Len(Time()) = 8 Then Print "time_len_ok"
If Len(Date()) > 0 Then Print "date_ok"
If Len(GetEXEName()) > 0 Then Print "exename_ok"
cl$ = CommandLine()
Print "cmdline_ok"

// End terminates the program: the line after it must never run.
Print "before_end"
End
Print "after_end"
