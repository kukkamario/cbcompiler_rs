' Redim to a LARGER size (FD-049 review F15). Redim replaces the variable with a
' fresh, zero-initialised array — it does not preserve the old contents.
Dim arr As Int[] = New Int[3]
arr[0] = 11
arr[1] = 22
arr[2] = 33
Print "len before: " + Str(Len(arr))
Redim arr As Int[6]
Print "len after: " + Str(Len(arr))
Print Str(arr[0])           ' fresh array → zero-filled, not 11
Print Str(arr[5])           ' the new tail slot → 0
arr[5] = 99
Print Str(arr[5])
