// FD-004 #10: `Select` rejects more than one `Default` arm.

Select x
    Case 1
        Print 1
    Default
        Print 99
    Default
        Print 100
EndSelect

// Three defaults — each extra one diagnosed independently.
Select y
    Default
        a = 1
    Default
        b = 2
    Default
        c = 3
EndSelect
